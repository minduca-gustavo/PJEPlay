{
  "version": "2.0.8",
  "short_name": "Rota PJE",
  "name": "Rota PJE",
  "description": "Atua como auxiliar para a execução de tarefas no PJE, fornecendo um roteiro operacional e recursos adicionais para facilitar o uso do sistema.",
  "author": "Rota PJE",
  "manifest_version": 3,
  "browser_specific_settings": {
    "gecko": {
      "id": "pje-play@extensao.local",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ],
        "optional": []
      }
    }
  },
  "action": {
    "default_popup": "navegador/paginas/menu/pagina.htm",
    "default_icon": "imagens/icon32.png"
  },
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "*://*.jus.br/*"
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "*://*.jus.br/*"
      ],
      "resources": [
        "utils/pdfjs.mjs",
        "utils/pdfjs.worker.mjs",
        "imagens/*.png",
        "documento/paginas/pje/rota/superfiltro.js",
        "rota/formatadores.js",
        "modulos/definicoes.js",
        "modulos/relatar.js",
        "rota/assistente/assistente.html",
        "rota/assistente/assistente.css",
        "rota/assistente/assistente.js",
        "rota/assistente/conector.js",
        "rota/acoes.js",
        "rota/configuracao.js",
        "rota/estado.js",
        "rota/cache.js",
        "rota/componentes.js",
        "modulos/dom.js",
        "modulos/execucao.js",
        "modulos/navegador.js",
        "modulos/texto.js",
        "rota/tarefas/index.js",
        "rota/tarefas/balcao-virtual/roteiro.js",
        "rota/tarefas/triagem-inicial/roteiro.js",
        "rota/tarefas/pos-triagem/roteiro.js"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "melhor-leitura/conteudo.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.jus.br/pjekz/*"
      ],
      "js": [
        "rota/interceptador-xhr.js"
      ],
      "all_frames": true,
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": [
        "*://*.jus.br/pjekz/*"
      ],
      "js": [
        "modulos/console.js",
        "modulos/definicoes.js",
        "modulos/relatar.js",
        "modulos/dom.js",
        "modulos/execucao.js",
        "modulos/navegador.js",
        "modulos/texto.js",
        "rota/configuracao.js",
        "rota/estado.js",
        "rota/cache.js",
        "rota/modelo.js",
        "rota/interceptador.js",
        "modulos/seletores.js",
        "rota/ui.js",
        "documento/paginas/pje/rota/pintura.js",
        "documento/paginas/pje/rota/janelas.js",
        "documento/paginas/pje/rota/botao-rota.js",
        "documento/paginas/pje/rota/iniciar.js",
        "documento/paginas/pje/rota/funcoes-da-planilha.js",
        "documento/paginas/pje/rota/porta-de-entrada.js",
        "documento/paginas/pje/rota/sf-botoes.js",
        "documento/paginas/pje/rota/superfiltro.js",
        "documento/paginas/pje/rota/teste.js",
        "documento/paginas/pje/rota/consulta-qualquer-oj.js",
        "documento/paginas/pje/rota/busca-posicao-fila.js",
        "documento/paginas/pje/rota/gigs.js",
        "rota/acoes.js",
        "rota/formatadores.js",
        "rota/componentes.js",
        "rota/tarefas/index.js",
        "rota/tarefas/balcao-virtual/roteiro.js",
        "rota/tarefas/triagem-inicial/roteiro.js",
        "rota/tarefas/pos-triagem/roteiro.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "scripts": [
      "modulos/definicoes.js",
      "modulos/relatar.js",
      "navegador/segundo-plano.js"
    ]
  },
  "icons": {
    "16": "imagens/icon16.png",
    "32": "imagens/icon32.png",
    "48": "imagens/icon48.png",
    "128": "imagens/icon128.png"
  }
}